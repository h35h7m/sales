@model Product

<h2 class="text-center text-primary mb-4">Edit Product</h2>

<div class="card shadow-sm p-4 mx-auto" style="max-width: 500px; border-radius: 15px;">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagePath" />

        <div class="mb-3">
            <label class="text-primary fw-bold">Name</label>
            <input asp-for="Name" class="form-control" style="background-color: #f0f8ff;" />
        </div>

        <div class="mb-3">
            <label class="text-primary fw-bold">Price</label>
            <input asp-for="Price" type="number" step="0.01" class="form-control" />
        </div>

        <div class="mb-3">
            <p>Current Image:</p>
            <img src="@Model.ImagePath" style="width: 100px; border-radius: 5px;" class="mb-2" />
            <label class="text-primary fw-bold d-block">Change Image Product</label>
            <input type="file" name="imageFile" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-3" style="border-radius: 10px;">Update</button>
    </form>
</div>